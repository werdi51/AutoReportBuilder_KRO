<Window x:Class="Exceller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Exceller"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800" >
    <Grid>

        <StackPanel Margin="20">

            <TextBlock Text="Автоматизация отчетов" FontSize="20" FontWeight="Bold" Margin="20"/>

            <Button Content="Выбрать папку с отчетами" Name="SelectFolder" Click="SelectFolder_Click" Height="40" Margin="10"/>

            <ProgressBar x:Name="WorkProgress" Height="20" Margin="10" Visibility="Collapsed"/>

            <ListBox x:Name="LogList" Height="200" d:ItemsSource="{d:SampleData ItemCount=5}"/>

        </StackPanel>
        
        
    </Grid>
</Window>
